# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&appName=AppName

# Alternative name that some platforms use
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&appName=AppName

# Server-only secrets
SESSION_SECRET=replace-with-a-long-random-string
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token